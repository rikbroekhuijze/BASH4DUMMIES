#!/bin/bash

VERSION="0.20.4"
MYBASENAME=$(basename "$0")

char1=$'\x01'
char2=$'\x02'
char3=$'\x03'
stopper="${char1}${char2}${char3}${char2}${char1}"

show_usage() {
    cat << EOF

Usage: $MYBASENAME <text> <amount> [<delimiter>]

Returns the last amount of tokens from a text string.
If n is negative, returns all but the first n tokens.

Parameters:
  text        - The string to extract from (can be passed via pipe)
  n           - Number of tokens to take:
                 positive: take first n tokens
                 negative: remove last n tokens
  delimiter   - Optional: character(s) that separate tokens (default: space)

Examples:
  $MYBASENAME "een twee drie vier" 2         # -> drie vier (default space)
  $MYBASENAME "een twee drie vier" -2        # -> drie vier (remove first 2)
  $MYBASENAME "a,b,c,d,e" 3 ','              # -> c,d,e
  $MYBASENAME "a,b,c,d,e" -2 ','             # -> c,d,e
  echo "one two three" | $MYBASENAME 2       # -> two three
  
  # Extract tokens from multi-line text
  echo "one two three
four five six
seven eight nine
ten"  | $MYBASENAME -3 $'\n'                 # -> ten

Options:
  -h, --help           Show this help message
  -v, --version        Show version information
  
in case you want --help, --version or -- itself as an argument:
  --                   End of options 
          
;°)
  
EOF
}

MAPFILE() {
    
    # Gebruik:
    # haystack="-1--test-3-"
    # delimiter="--"
    # MAPFILE "$haystack" "$delimiter" "fields" 
    # for (( i=0; i<${#fields[@]}; i++ )); do
    #     echo "$i : '${fields[$i]}'"
    # done
    
    # Check of er een array naam is meegegeven
    if [[ -z "$3" ]]; then
        echo "MYBASENAME: $MYBASENAME in function ${0##*/}: No array name given." >&2
        exit 123
    fi
    
    local string="$1"
    local delimiter="$2"
    local -n output_array="$3"  # nameref naar array
    
    [ -n "$debug" ] && echo 
    [ -n "$debug" ] && echo "function MAPFILE"
    [ -n "$debug" ] && echo 
    [ -n "$debug" ] && echo "string : $string"
    [ -n "$debug" ] && echo "delimiter : =>$delimiter<="
    [ -n "$debug" ] && echo "output_array : $3"
    
    output_array=()
    local current=""
    local abc=0
    local dlen=${#delimiter}
    local slen=${#string}
    local bcd=1  # start op index 1
    
    while [[ $abc -lt $slen ]]; do
        # Check if we have delimiter at position i
        if [[ "${string:$abc:$dlen}" == "$delimiter" ]]; then
            output_array["$bcd"]="$current"
            current=""
            ((abc += dlen))
            ((bcd++))
        else
            current+="${string:$abc:1}"
            ((abc++))
        fi
    done

    output_array["$bcd"]="$current"
    ((bcd++))
    
    [ -n "$debug" ] && echo 
    [ -n "$debug" ] && echo "aantal : ${#output_array[@]}" 
    if [ -n "$debug" ] ; then
      for (( abc=1; abc<=${#output_array[@]}; abc++ )); do
        echo "$abc : '${output_array[$abc]}'"
      done
    fi
   
}

TAIL() {
    
    local haystack="$1"
    local amount="$2"
    local delimiter="${3:- }"
    
    [ -n "$debug" ] && echo 
    [ -n "$debug" ] && echo "function TAIL"
    [ -n "$debug" ] && echo "amount : $amount"
    [ -n "$debug" ] && echo "haystack : $haystack"
    [ -n "$debug" ] && echo "delimiter : $delimiter"
    
    if [[ "$haystack" = "" ]]; then
      return 0
    fi
    
    # Validatie: amount moet een getal zijn
    if [[ ! "$amount" =~ ^-?[0-9]+$ ]]; then
        echo "$MYBASENAME: amount must be an integer" >&2
        return 123
    fi
    
    if [[ "$amount" -eq 0 ]]; then
      return 0
    fi
    
    # Split op delimiter 
    MAPFILE "$haystack" "$delimiter" "fields"
     
    local stopnumber
    local startnummer
    
    # Bereken start stop
    
    stopnumber="${#fields[@]}"
    
    [ "$amount" -eq 0 ] && return 0
    
    if [ "$amount" -gt 0 ]; then
        startnumber=$(( stopnumber + 1 - amount))
    else
        startnumber=$((1 - amount))
    fi
    
    if [ -n "$debug" ] ; then
      echo
      echo "startnumber : $startnumber"
      echo "stopnumber : $stopnumber"
    fi
    
    abc="$startnumber"
    string=""
    while [ $abc -le "$stopnumber" ]; do
      
      if [[ "$string" = "" ]];then
        string="${fields["$abc"]}"
      else
        string="${string}${delimiter}${fields[abc]}"
      fi
      
      [ -n "$debug" ] && echo
      [ -n "$debug" ] && echo "string : $string"
      
      ((abc++))
      
    done
    
    [ -n "$debug" ] && echo
    
    if [[ ! -z "$string" ]]; then
      echo "$string"
    fi
    
    return 0
    
}

# MAIN 
args=()

# Check voor pipe input
if read -t 0.01 -r -n 1 eerste_karakter; then
    # Er is daadwerkelijk data. Lees de rest, voeg de marker toe en knip 'm er weer af. (grab the newline)
    rest=$(cat; echo "$stopper")
    stdin_content="${eerste_karakter}${rest}"
    # Verwijder marker + eventuele newline
    stdin_content="${stdin_content%$stopper}"
    stdin_content="${stdin_content%$'\n'}"
    # we willen "" ook vangen.
    # if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    # fi
fi

debug=""
endofoptions=""
for arg in "$@"; do

    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
           
        -d|--debug)
            if [ -z "$endofoptions" ]; then
              debug="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1" 
              endofoptionstoggle="1"
            else
              args+=("$arg")
            fi
            ;;
                
    #    -*)
    #        # what about a megative number ?
    #        if [ -z "$endofoptions" ]; then
    #          args+=("$arg")
    #        else
    #          echo "$MYBASENAME: Unknown option $arg" >&2
    #          exit 123
    #        fi
    #        ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
    
done

# Valideer aantal argumenten
if [ "${#args[@]}" -lt 2 ]; then
    echo "$MYBASENAME: Need at least text and n" >&2
    exit 123
fi

if [ "${#args[@]}" -gt 3 ]; then
    echo "$MYBASENAME: Too many arguments" >&2
    exit 123
fi

TAIL "${args[@]}"
[ -n "$debug" ] && echo 
exit $?
