#!/bin/bash

VERSION="0.20.3"
MYBASENAME=$(basename "$0")

char1=$'\x01'
char2=$'\x02'
char3=$'\x03'
stopper="${char1}${char2}${char3}${char2}${char1}"

show_usage() {
    cat << EOF

Usage: $MYBASENAME <text> <n>

Returns the first n characters from the left side of a text string.
If n is negative, returns all but the last n characters.

Parameters:
  text        - The string to extract from (can be passed via pipe)
  n           - Number of characters to extract:
                 positive: take first n characters
                 negative: remove last n characters
                 zero: returns empty string

Examples:
  $MYBASENAME "Hello world" 5          # -> Hello
  $MYBASENAME "Hello world" -5         # -> Hello (removes last 5)
  echo "Hello world" | $MYBASENAME 5
  $MYBASENAME "Hello" 10               # -> Hello (whole string if n > length)

Options:
  -h, --help     Show this help message
  -v, --version  Show version information

EOF
}

LEFT() {
    local string="$1"
    local n="$2"
    
    # Validatie: n moet een getal zijn
    if [[ ! "$n" =~ ^-?[0-9]+$ ]]; then
        echo "ERROR: n must be an integer" >&2
        return 123
    fi
    
    local result=""
    
    if [ "$n" -ge 0 ]; then
        # Positief: eerste n karakters
        result="${string:0:$n}"
    else
        # Negatief: verwijder laatste |n| karakters
        local remove=$(( -n ))
        result="${string:0:${#string}-remove}"
    fi
    
    # Alleen output als resultaat niet leeg is
    if [ -n "$result" ]; then
        echo "$result"
    fi
}

# MAIN 
args=()

# Check voor pipe input
# Vervang de hele check door dit blok
if read -t 0.01 -r -n 1 eerste_karakter; then
    # Er is daadwerkelijk data. Lees de rest, voeg de marker toe en knip 'm er weer af.
    rest=$(cat; echo "$stopper")
    stdin_content="${eerste_karakter}${rest}"
    # Verwijder marker + eventuele newline
    stdin_content="${stdin_content%$stopper}"
    stdin_content="${stdin_content%$'\n'}"
    # we willen "" ook vangen.
    # if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    # fi
fi

debug=""
verbose=""
dryrun=""
silent=""
endofoptions=""
for arg in "$@"; do
    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
           
        -d|--debug)
            if [ -z "$endofoptions" ]; then
              debug="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --verbose)
            if [ -z "$endofoptions" ]; then
              verbose="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --dryrun)
            if [ -z "$endofoptions" ]; then
              dryrun="1"
            else
              args+=("$arg")
            fi
            ;;
        
        -s|--silent)
            if [ -z "$endofoptions"]; then
              silent="1"
            else
              args+=("$arg")
            fi
            ;;
        
        
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1"  
            else
              args+=("$arg")
            fi
            ;;
                
        -*)
            if [ -z "$endofoptions" ]; then
              args+=("$arg")
            else
              echo "ERROR: Unknown option $arg" >&2
              show_usage
              exit 123
            fi
            ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
done

if [ "${#args[@]}" -gt 2 ]; then
    echo "ERROR: Too many arguments" >&2
    # show_usage
    exit 123
fi

LEFT "${args[@]}"
exit $?
