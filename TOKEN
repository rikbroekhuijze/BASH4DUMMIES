#!/bin/bash

VERSION="0.20.2"
MYBASENAME=$(basename "$0")

char1=$'\x01'
char2=$'\x02'
char3=$'\x03'
stopper="${char1}${char2}${char3}${char2}${char1}"

show_usage() {
    cat << EOF

Usage: $MYBASENAME <text> <n> [<delimiter>]

Extracts the n-th token from a text string.
Tokens are separated by delimiter (default: space).

Parameters:
  text        - The string to extract from (can be passed via pipe)
  n           - Token number to extract:
                 positive: count from the start (1 = first token)
                 negative: count from the end (-1 = last token)
                 0 is invalid
  delimiter   - Optional: character(s) that separate tokens (default: space)

Examples:
  $MYBASENAME "one two three four five" 3       # -> three
  $MYBASENAME "one two three four five" -1      # -> five (last token)
  $MYBASENAME "one two three four five" -2      # -> four (second last)
  echo "one,two,three,four,five" | $MYBASENAME -2 ','
  $MYBASENAME "one--two--three" 2 "--"          # Multi-char delimiter
  $MYBASENAME "--test--" 1 "--"                  # Delimiter that looks like an option
  
  # Extract third line from multi-line text
  echo "line one
line two
line three
line four" | $MYBASENAME -2 $'\n'               # -> line three

Options:
  -h, --help     Show this help message
  -v, --version  Show version information

EOF
}

TOKEN() {
    
    local haystack="$1"
    local n="$2"
    local delimiter="$3"
    
    # Als delimiter niet is meegegeven, gebruik spatie
    if [ -z "$delimiter" ]; then
        delimiter=" "
    fi
    
    # Validatie: n moet een getal zijn en mag niet 0 zijn
    if [[ ! "$n" =~ ^-?[0-9]+$ ]] || [ "$n" -eq 0 ]; then
        echo "ERROR: n must be a non-zero integer" >&2
        return 1
    fi
    
    # Split de string op delimiter
    local tokens=()
    
    mapfile -d "$delimiter"  -t tokens <<< "$haystack""bla"
    
    # Na het splitten, 
    if [ "${#tokens[@]}" -gt 0 ]; then
      last=${#tokens[@]}-1
      if [ "${tokens[$last]: -3}" = "bla" ]; then
        tokens[$last]="${tokens[$last]%???}"  # Verwijder laatste 3 karakters
      else
        tokens[$last]="${tokens[$last]%????}"  # Verwijder laatste 4 karakters
      fi
    fi
    
    # Bereken de effectieve index
    local index
    if [ "$n" -gt 0 ]; then
        index=$((n - 1))
    else
        index=$((${#tokens[@]} + n))
    fi
    
    # Check of token bestaat
    if [ "$index" -lt 0 ] || [ "$index" -ge "${#tokens[@]}" ]; then
        return 1
    fi
    
    # Alleen echoën als token niet leeg is
    if [ -n "${tokens[index]}" ]; then
        echo "${tokens[index]}"
    fi
    
}

# MAIN 
args=()

# Check voor pipe input
# Vervang de hele check door dit blok
if read -t 0.01 -r -n 1 eerste_karakter; then
    # Er is daadwerkelijk data. Lees de rest, voeg de marker toe en knip 'm er weer af.
    rest=$(cat; echo "$stopper")
    stdin_content="${eerste_karakter}${rest}"
    # Verwijder marker + eventuele newline
    stdin_content="${stdin_content%$stopper}"
    stdin_content="${stdin_content%$'\n'}"
    # we willen "" ook vangen.
    # if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    # fi
fi

debug=""
verbose=""
dryrun=""
silent=""
endofoptions=""
for arg in "$@"; do
    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
           
        -d|--debug)
            if [ -z "$endofoptions" ]; then
              debug="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --verbose)
            if [ -z "$endofoptions" ]; then
              verbose="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --dryrun)
            if [ -z "$endofoptions" ]; then
              dryrun="1"
            else
              args+=("$arg")
            fi
            ;;
        
        -s|--silent)
            if [ -z "$endofoptions"]; then
              silent="1"
            else
              args+=("$arg")
            fi
            ;;
        
        
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1"  
            else
              args+=("$arg")
            fi
            ;;
                
        -*)
            if [ -z "$endofoptions" ]; then
              args+=("$arg")
            else
              echo "ERROR: Unknown option $arg" >&2
              show_usage
              exit 123
            fi
            ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
done

# Check bash versie (mapfile bestaat sinds bash 4.0)
if [ "${BASH_VERSINFO[0]}" -lt 4 ]; then
  echo "Warning: Your bash version is ${BASH_VERSINFO[0]}.${BASH_VERSINFO[1]}" >&2
  echo "mapfile needs bash 4.0 or higher. Upgrade bash for full support." >&2
  exit 123
fi

# Valideer aantal argumenten
if [ "${#args[@]}" -lt 2 ]; then
    echo "ERROR: Need at least text and token number" >&2
    show_usage
    exit 1
fi

if [ "${#args[@]}" -gt 3 ]; then
    echo "ERROR: Too many arguments" >&2
    show_usage
    exit 1
fi

 # Debug: toon args (uitcommentarieer voor testen)
# echo "args: ${#args[@]}" >&2
 #for i in "${!args[@]}"; do
 #    echo "  $i: '${args[i]}'" >&2
 #done

# Roep TOKEN aan

TOKEN "${args[@]}"
exit $?
