#!/bin/bash

VERSION="0.20.7"
MYBASENAME=$(basename "$0")

char1=$'\x01'
char2=$'\x02'
char3=$'\x03'
stopper="${char1}${char2}${char3}${char2}${char1}"

show_usage() {
    cat << EOF

Usage: $MYBASENAME <text> <n> [<delimiter>]

Extracts the n-th token from a text string.
Tokens are separated by delimiter (default: space).

Parameters:
  text        - The string to extract from (can be passed via pipe)
  n           - Token number to extract:
                 positive: count from the start (1 = first token)
                 negative: count from the end (-1 = last token)
                 0 is invalid
  delimiter   - Optional: character(s) that separate tokens (default: space)

Examples:
  $MYBASENAME "one two three four five" 3       # -> three
  $MYBASENAME "one two three four five" -2      # -> four (second last token)
  $MYBASENAME "one,two,three,four,five" -2 ","  # -> four (delimiter is ',')
  echo "one,two,three,four,five" | $MYBASENAME -2 ','  # -> four
  $MYBASENAME "--test--" 2 -- "--"              # endofoptions as deliliter
  
  # Extract third line from multi-line text
  echo "line one
line two
line three
line four" | $MYBASENAME -2 $'\n'               # -> line three

Options:
  -h, --help           Show this help message
  -v, --version        Show version information
  
in case you want --help, --version or -- itself as an argument:
  --                   End of options 
          
;°)
  
EOF
}

MAPFILE() {
    
    # Gebruik:
    # haystack="-1--test-3-"
    # delimiter="--"
    # MAPFILE "$haystack" "$delimiter" "fields" 
    # for (( i=0; i<${#fields[@]}; i++ )); do
    #     echo "$i : '${fields[$i]}'"
    # done
    
    # Check of er een array naam is meegegeven
    if [[ -z "$3" ]]; then
        echo "MYBASENAME: ERROR in function ${0##*/}: No array name given." >&2
        exit 123
    fi
    
    local string="$1"
    local delimiter="$2"
    local -n output_array="$3"  # nameref naar array
    
    [ -n "$debug" ] && echo 
    [ -n "$debug" ] && echo "function MAPFILE"
    [ -n "$debug" ] && echo 
    [ -n "$debug" ] && echo "string : $string"
    [ -n "$debug" ] && echo "delimiter : =>$delimiter<="
    [ -n "$debug" ] && echo "output_array : $output_array"
    
    output_array=()
    local current=""
    local abc=0
    local dlen=${#delimiter}
    local slen=${#string}
    local bcd=1  # start op index 1
    
    while [[ $abc -lt $slen ]]; do
        # Check if we have delimiter at position i
        if [[ "${string:$abc:$dlen}" == "$delimiter" ]]; then
            output_array["$bcd"]="$current"
            current=""
            ((abc += dlen))
            ((bcd++))
        else
            current+="${string:$abc:1}"
            ((abc++))
        fi
    done

    output_array["$bcd"]="$current"
    ((bcd++))
    
    [ -n "$debug" ] && echo 
    [ -n "$debug" ] && echo "aantal : ${#output_array[@]}" 
    if [ -n "$debug" ] ; then
      for (( abc=1; abc<=${#output_array[@]}; abc++ )); do
        echo "$abc : '${output_array[$abc]}'"
      done
    fi
   
}

TOKEN() {
    
    local haystack="$1"
    local n="$2"
    local delimiter="$3"
    
    [ -n "$debug" ] && echo 
    [ -n "$debug" ] && echo "function TOKEN"
    [ -n "$debug" ] && echo 
    [ -n "$debug" ] && echo "haystack : $haystack"
    [ -n "$debug" ] && echo "n : $n"
    [ -n "$debug" ] && echo "delimiter : =>$delimiter<="
    
    [ "$n" -eq 0 ] && exit 0
    
    # Als delimiter niet is meegegeven, gebruik spatie
    if [ -z "$delimiter" ]; then
        delimiter=" "
    fi
    
    [ -n "$debug" ] && echo "delimiter : =>$delimiter<="
    
    # Validatie: n moet een getal zijn en mag niet 0 zijn
    if [[ ! "$n" =~ ^-?[0-9]+$ ]] || [ "$n" -eq 0 ]; then
        echo "$MYBASENAME: n must be a non-zero integer" >&2
        return 123
    fi
    
    # Split op delimiter 
    MAPFILE "$haystack" "$delimiter" "fields"
    
    [ -n "$debug" ] && echo  
    [ -n "$debug" ] && echo "aantal : ${#fields[@]}" 
    if [ -n "$debug" ]; then
      for (( abc=1;abc<="${#fields[@]}";abc++ )) ; do
        echo "$abc : ${fields["$abc"]}"
      done
    fi
     
    # Bereken de effectieve index
    local index
    if [ "$n" -gt 0 ]; then
        index="$n"
    else
        index=$((${#fields[@]} + n + 1))
    fi
    
    [ -n "$debug" ] && echo 
    [ -n "$debug" ] && echo "index : $index"
    
    # Check of token bestaat
    if [ "$index" -lt 0 ] || [ "$index" -gt "${#fields[@]}" ]; then
    [ -n "$debug" ] && echo "token bestaat niet."
        return 1
    fi
    
    # Alleen echoën als token niet leeg is
    if [ -n "${fields[index]}" ]; then
        echo "${fields[index]}"
    else
      [ -n "$debug" ] && echo "token is leeg."
    fi
    
}

# MAIN 
args=()

# Check voor pipe input
if read -t 0.01 -r -n 1 eerste_karakter; then
    # Er is daadwerkelijk data. Lees de rest, voeg de marker toe en knip 'm er weer af. (grab the newline)
    rest=$(cat; echo "$stopper")
    stdin_content="${eerste_karakter}${rest}"
    # Verwijder marker + eventuele newline
    stdin_content="${stdin_content%$stopper}"
    stdin_content="${stdin_content%$'\n'}"
    # we willen "" ook vangen.
    # if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    # fi
fi

debug=""
endofoptions=""
for arg in "$@"; do

    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
           
        -d|--debug)
            if [ -z "$endofoptions" ]; then
              debug="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1" 
              endofoptionstoggle="1"
            else
              args+=("$arg")
            fi
            ;;
                
    #    -*)
    #        # what about a megative number ?
    #        if [ -z "$endofoptions" ]; then
    #          args+=("$arg")
    #        else
    #          echo "$MYBASENAME: Unknown option $arg" >&2
    #          exit 123
    #        fi
    #        ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
    
done

# Valideer aantal argumenten
if [ "${#args[@]}" -lt 2 ]; then
    echo "$MYBASENAME: Need at least text and token number" >&2
    #show_usage
    exit 123
fi

if [ "${#args[@]}" -gt 3 ]; then
    echo "$MYBASENAME: Too many arguments" >&2
    #show_usage
    exit 123
fi

# Debug: toon args
[ -n "$debug" ] && echo 
if [ -n "$debug" ] ; then
  echo "args: ${#args[@]}" 
  for abc in "${!args[@]}"; do
     echo "  $abc: '${args[abc]}'" 
  done
fi

# Roep TOKEN aan
TOKEN "${args[@]}"
[ -n "$debug" ] && echo 
exit $?
