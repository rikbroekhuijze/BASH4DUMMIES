#!/bin/bash

VERSION="0.20.4"
MYBASENAME=$(basename "$0")

char1=$'\x01'
char2=$'\x02'
char3=$'\x03'
stopper="${char1}${char2}${char3}${char2}${char1}"

show_usage() {
    cat << EOF

Usage: $MYBASENAME <text> <start> <length>

Extracts a substring starting at position with given length.
Negative values count from the end.

Parameters:
  text        - The string to extract from (can be passed via pipe)
  start       - Start position (1 = first, -1 = last)
  length      - Number of characters:
                 positive = take characters to the right
                 negative = take characters to the left

Examples:
  $MYBASENAME "blablabla" 2 3        # -> lab (start at 2, take 3 right)
  $MYBASENAME "blablabla" -2 -3      # -> abl (start at -2, take 3 left)
  $MYBASENAME "Hello world" 4 5      # -> lo wo
  $MYBASENAME "Hello world" -5 3     # -> wor (start at -5, take 3 right)
  $MYBASENAME "Hello world" 3 -2     # -> l (start at 3, take 2 left)

Options:
  -h, --help           Show this help message
  -v, --version        Show version information
  
    in case you want --help, --version or -- itself as an argument:
  --                   End of options 
          
;°)
  
EOF
}

MID() {
    local string="$1"
    local start="$2"
    local length="$3"
    local len=${#string}
    local result=""
    
    # Validatie
    if [[ ! "$start" =~ ^-?[0-9]+$ ]] || [[ ! "$length" =~ ^-?[0-9]+$ ]]; then
        echo "$MYBASENAME: start and length must be integers" >&2
        return 1
    fi
    
    # Converteer start naar 0-based index
    if [ "$start" -gt 0 ]; then
        start=$((start - 1))
    elif [ "$start" -lt 0 ]; then
        start=$((len + start))
    else
        # start == 0 is invalid (1-based counting starts at 1)
        return 1
    fi
    
    # Check of start binnen bereik is
    if [ "$start" -lt 0 ] || [ "$start" -ge "$len" ]; then
        return 1
    fi
    
    # Bereken substring op basis van lengte
    if [ "$length" -gt 0 ]; then
        # Positieve lengte: naar rechts
        result="${string:$start:$length}"
    elif [ "$length" -lt 0 ]; then
        # Negatieve lengte: naar links
        local left_start=$((start + length + 1))
        local left_length=$(( -length ))
        
        # Check of left_start binnen bereik is
        if [ "$left_start" -lt 0 ]; then
            left_start=0
            left_length=$((start + 1))
        fi
        
        result="${string:$left_start:$left_length}"
    else
        # length == 0: lege string
        result=""
    fi
    
    # Alleen output als resultaat niet leeg is
    if [ -n "$result" ]; then
        echo "$result"
    fi
}

# MAIN 
args=()

# Check voor pipe input
if read -t 0.01 -r -n 1 eerste_karakter; then
    # Er is daadwerkelijk data. Lees de rest, voeg de marker toe en knip 'm er weer af. (grab the newline)
    rest=$(cat; echo "$stopper")
    stdin_content="${eerste_karakter}${rest}"
    # Verwijder marker + eventuele newline
    stdin_content="${stdin_content%$stopper}"
    stdin_content="${stdin_content%$'\n'}"
    # we willen "" ook vangen.
    # if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    # fi
else
  # pipe or file
  if [ -p /dev/stdin ] || [ -f /dev/stdin ] ; then
    stdin_content=$(cat; echo "$stopper")
    stdin_content="${stdin_content%$stopper}"
    stdin_content="${stdin_content%$'\n'}"
    # we willen "" ook vangen.
    # if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    # fi
  fi
fi

debug=""
endofoptions=""
for arg in "$@"; do

    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
           
        -d|--debug)
            if [ -z "$endofoptions" ]; then
              debug="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1" 
              endofoptionstoggle="1"
            else
              args+=("$arg")
            fi
            ;;
                
    #    -*)
    #        # what about a megative number ?
    #        if [ -z "$endofoptions" ]; then
    #          args+=("$arg")
    #        else
    #          echo "$MYBASENAME: Unknown option $arg" >&2
    #          exit 123
    #        fi
    #        ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
    
done

# Valideer aantal argumenten
if [ "${#args[@]}" -lt 3 ]; then
    echo "$MYBASENAME: Need text, start position, and length" >&2
    show_usage
    exit 123
fi

if [ "${#args[@]}" -gt 3 ]; then
    echo "$MYBASENAME: Too many arguments" >&2
    show_usage
    exit 123
fi

MID "${args[@]}"
exit $?
