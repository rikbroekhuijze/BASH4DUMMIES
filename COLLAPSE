#!/bin/bash

VERSION="0.20.9"
MYBASENAME=$(basename "$0")

char1=$'\x01'
char2=$'\x02'
char3=$'\x03'
stopper="${char1}${char2}${char3}${char2}${char1}"

show_usage() {
    cat << EOF

Usage: $MYBASENAME <string> [<delimiter>]

Collapses multiple consecutive delimiters into a single delimiter.
Default delimiter is space.

Parameters:
  string      - The string to collapse (can be passed via pipe)
  delimiter   - Optional: character(s) that separate tokens (default: space)

Examples:
  $MYBASENAME "one    two   three"              # -> one two three
  $MYBASENAME "one,,,two,,,three" ','           # -> one,two,three
  $MYBASENAME "one  two  three  "               # -> one two three (no trailing)
  echo "one    two   three" | $MYBASENAME       # -> one two three
  $MYBASENAME $'one\n\n\ntwo\n\nthree' $'\n'    # -> one\ntwo\nthree

Options:
  -h, --help           Show this help message
  -v, --version        Show version information
  
  in case you want --help, --version or -- itself as an argument:
  --                   End of options 
          
;°)
  
EOF
}

# check only voor verbose & debug first.
verbose=""
debug=""
for arg in "$@"; do
    [ "$arg" = "--" ] && break
    if [ "$arg" = "--verbose" ]; then
        verbose=1
        break
    fi
    if [ "$arg" = "--debug" ]; then
        set -x
        break
    fi
done

COLLAPSE() {
    
    local string="$1"
    local delimiter="${2:- }"
    local result=""
    local tokens=()
    
    if [ -z "$string" ]; then
        return 0
    fi
 
    for (( abc=${#string}-1; abc>=1; abc-- )); do
      
      char1="${string:$abc:1}"
      
      if [ "$char1" = "$delimiter" ] ; then
        
        bcd=$(( abc-1 ))
        char2="${string:$bcd:1}" 
      
        if [ "$char1" = "$char2" ] ; then
        
          # verwijder positie abc
          voor="${string:0:$abc}"          # deel voor de positie
          na="${string:$abc+1}"            # deel na de positie
          string="${voor}${na}"
          
        fi
        
      fi
      
    done
    
    # Alleen als er output was
    if [ ! -z "$string" ] ; then
      echo "$string"
    fi
    
}

# MAIN 
args=()

#
# Check voor pipe input
if IFS='' read -t 0.01 -r -n 1 eerste_karakter; then
    # Er is daadwerkelijk data. Lees de rest, voeg de marker toe en knip 'm er weer af. (grab the newline)
    rest=$(cat; echo "$stopper")
    stdin_content="${eerste_karakter}${rest}"
    # Verwijder marker + eventuele newline
    stdin_content="${stdin_content%$stopper}"
    stdin_content="${stdin_content%$'\n'}"
    # we willen "" ook vangen.
    # if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    # fi
# else
  # # pipe or file
  # # bacon (en anderen) openen een pipe intern. beiden (-p en -f ) reageren daarop.
  # if [ -p /dev/stdin ] || [ -f /dev/stdin ] ; then
  #   stdin_content=$(cat; echo "$stopper")
  #   stdin_content="${stdin_content%$stopper}"
  #   stdin_content="${stdin_content%$'\n'}"
  #   # we willen "" ook vangen.
  #   # if [ -n "$stdin_content" ]; then
  #       args+=("$stdin_content")
  #   # fi
 #  fi
fi

[ -n "$verbose" ] && echo
endofoptions=""
for arg in "$@"; do
   
    [ -n "$verbose" ] && echo "arg : $arg"
    
    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--verbose|-d|--debug)
        
           if NOT ISNULL "$endofoptions"; then args+=("$arg") ; fi
           ;;
            
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1" 
              endofoptionstoggle="1"
            else
              args+=("$arg")
            fi
            ;;
                
    #    -*)
    #        # what about a megative number ?
    #        if [ -z "$endofoptions" ]; then
    #          args+=("$arg")
    #        else
    #          echo "$MYBASENAME: Unknown option $arg" >&2
    #          exit 123
    #        fi
    #        ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
    
done

if [ "${#args[@]}" -gt 2 ]; then
    echo "$MYBASENAME: Too many arguments" >&2
    # show_usage
    exit 123
fi

COLLAPSE "${args[@]}"
exit $?
