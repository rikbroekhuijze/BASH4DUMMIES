#!/bin/bash

VERSION="0.20.9"
MYBASENAME=$(basename "$0")

char1=$'\x01'
char2=$'\x02'
char3=$'\x03'
stopper="${char1}${char2}${char3}${char2}${char1}"

show_usage() {
    cat << EOF
Usage: $MYBASENAME <haystack> <needle> [<start>]

Finds the position of a substring in a string.
Returns the position (1-based) of the first occurrence, or 0 if not found.

Parameters:
  haystack    - The string to search in (can be passed via pipe)
  needle      - The substring to look for
  start       - Optional: start searching from this position (1-based).
                 Negative values count from the end (-1 = last character).

Examples:
  $MYBASENAME "Hello world" "world"              # -> 7
  $MYBASENAME "Hello world" "lo"                 # -> 4
  $MYBASENAME "Hello world" "xyz"                # -> 0
  $MYBASENAME "Hello world" "o" 5                # -> 5 (start at position 5)
  $MYBASENAME "Hello world" "o" 6                # -> 8 (start at position 6)
  $MYBASENAME "Hello world" "o" -1               # -> 8 (start from last char)
  $MYBASENAME "Hello world" "o" -3               # -> 5 (start from 3rd from end)
  $MYBASENAME "ababa" "aba" -1                   # -> 3 (last occurrence)
  echo "Hello world" | $MYBASENAME "world"       # -> 7

Options:
  -h, --help           Show this help message
  -v, --version        Show version information
  --                   End of options 
          
;°)
  
EOF
}

# check only voor verbose & debug first.
verbose=""
debug=""
for arg in "$@"; do
    [ "$arg" = "--" ] && break
    if [ "$arg" = "--verbose" ]; then
        verbose=1
        # break
    fi
    if [ "$arg" = "--debug" ]; then
        set -x
        # break
    fi
done

INSTR() {
    
    local haystack="$1"
    local needle="$2"
    local start="${3:-1}"
    local pos=0
    local len=${#haystack}
    
    # Validatie
    if [ -z "$haystack" ] || [ -z "$needle" ]; then
        echo 0
        return 1
    fi
    
    NOT ISNULL "$verbose" && echo
    NOT ISNULL "$verbose" && echo "start : $start"
    
    # Bepaal startpositie (1-based)
    local start_pos
    if [[ "$start" =~ ^-?[0-9]+$ ]]; then
    # if NOT ISINT "$start"; then  # no ISINT doesnot grab negative ints
        if [ "$start" -gt 0 ]; then
            start_pos=$start
        elif [ "$start" -lt 0 ]; then
            start_pos=$((len + start + 1))
        else
            start_pos=1
        fi
    else
        echo "$MYBASENAME: start must be an integer" >&2
        return 1
    fi
    
    start="$start_pos"
    
    NOT ISNULL "$verbose" && echo "start : $start"
    
    if [[ ! "$start" =~ ^[0-9]+$ ]] || [ "$start" -lt 1 ]; then
        echo "$MYBASENAME: start position must be a positive integer" >&2
        return 1
    fi
    
    # Converteer naar 0-based voor bash substring
    local start_0=$((start - 1))
    
    # Als start buiten bereik is
    if [ "$start_0" -ge "${#haystack}" ]; then
        echo 0
        return 1
    fi
    
    # Zoek vanaf startpositie
    local search_section="${haystack:$start_0}"
    local prefix="${search_section%%"$needle"*}"
    
    if [ "$prefix" != "$search_section" ]; then
        # Gevonden: bereken positie
        pos=$((start_0 + ${#prefix} + 1))
        echo "$pos"
        return 0
    else
        echo 0
        return 1
    fi
}

# MAIN 
args=()

#
# Check voor pipe input
if read -t 0.01 -r -n 1 eerste_karakter; then
    # Er is daadwerkelijk data. Lees de rest, voeg de marker toe en knip 'm er weer af. (grab the newline)
    rest=$(cat; echo "$stopper")
    stdin_content="${eerste_karakter}${rest}"
    # Verwijder marker + eventuele newline
    stdin_content="${stdin_content%$stopper}"
    stdin_content="${stdin_content%$'\n'}"
    # we willen "" ook vangen.
    # if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    # fi
# else
  # # pipe or file
  # # bacon (en anderen) openen een pipe intern. beiden (-p en -f ) reageren daarop.
  # if [ -p /dev/stdin ] || [ -f /dev/stdin ] ; then
  #   stdin_content=$(cat; echo "$stopper")
  #   stdin_content="${stdin_content%$stopper}"
  #   stdin_content="${stdin_content%$'\n'}"
  #   # we willen "" ook vangen.
  #   # if [ -n "$stdin_content" ]; then
  #       args+=("$stdin_content")
  #   # fi
 #  fi
fi

[ -n "$verbose" ] && echo
endofoptions=""
for arg in "$@"; do
   
    [ -n "$verbose" ] && echo "arg : $arg"
    
    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--verbose|-d|--debug)
        
           if NOT ISNULL "$endofoptions"; then args+=("$arg") ; fi
           ;;
            
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1" 
              endofoptionstoggle="1"
            else
              args+=("$arg")
            fi
            ;;
                
    #    -*)
    #        # what about a megative number ?
    #        if [ -z "$endofoptions" ]; then
    #          args+=("$arg")
    #        else
    #          echo "$MYBASENAME: Unknown option $arg" >&2
    #          exit 123
    #        fi
    #        ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
    
done

if [ -n "$verbose" ] ; then
  echo
  echo "number of arguments : ${#args[@]}"
  echo "stdin_content : $stdin_content"
  for ((abc=0; abc<${#args[@]}; abc++)); do
    echo "argument $abc : ${args[$((abc))]}"
  done
  echo
fi

# Valideer aantal argumenten
if [ "${#args[@]}" -lt 2 ]; then
    echo "$MYBASENAME: Need haystack and a needle" >&2
    exit 123
fi

if [ "${#args[@]}" -gt 3 ]; then
    echo "$MYBASENAME: Too many arguments" >&2
    exit 123
fi

INSTR "${args[@]}"
exit $?
