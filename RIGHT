#!/bin/bash

VERSION="0.20"
MYBASENAME=$(basename "$0")

char1=$'\x01'
char2=$'\x02'
char3=$'\x03'
stopper="${char1}${char2}${char3}${char2}${char1}"

show_usage() {
    cat << EOF

Usage: $MYBASENAME <text> <n>

Returns the last n characters from the right side of a text string.
If n is negative, returns all but the first n characters.

Parameters:
  text        - The string to extract from (can be passed via pipe)
  n           - Number of characters to extract:
                 positive: take last n characters
                 negative: remove first n characters
                 zero: returns empty string

Examples:
  $MYBASENAME "Hello world" 5          # -> world
  $MYBASENAME "Hello world" -5         # -> world (removes first 5)
  echo "Hello world" | $MYBASENAME 5
  $MYBASENAME "Hello" 10               # -> Hello (whole string if n > length)

Options:
  -h, --help     Show this help message
  -v, --version  Show version information

EOF
}

RIGHT() {
    local string="$1"
    local n="$2"
    
    # Validatie: n moet een getal zijn
    if [[ ! "$n" =~ ^-?[0-9]+$ ]]; then
        echo "ERROR: n must be an integer" >&2
        return 1
    fi
    
    local result=""
    
    if [ "$n" -ge 0 ]; then
        # Positief: laatste n karakters
        if [ "$n" -ge ${#string} ]; then
            result="$string"
        else
            result="${string: -$n}"
        fi
    else
        # Negatief: verwijder eerste |n| karakters
        local remove=$(( -n ))
        if [ "$remove" -ge ${#string} ]; then
            result=""
        else
            result="${string:$remove}"
        fi
    fi
    
    # Alleen output als resultaat niet leeg is
    if [ -n "$result" ]; then
        echo "$result"
    fi
}

# MAIN 
args=()

# Check voor pipe input
if read -t 0 -n 0; then
    stdin_content=$(cat; echo "$stopper")
    if [ "${#stdin_content}" -gt "5" ] ;then
      stdin_content="${stdin_content::-6}"
      if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
      fi
    fi
fi

debug=""
verbose=""
dryrun=""
silent=""
endofoptions=""
for arg in "$@"; do
    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
           
        -d|--debug)
            if [ -z "$endofoptions" ]; then
              debug="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --verbose)
            if [ -z "$endofoptions" ]; then
              verbose="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --dryrun)
            if [ -z "$endofoptions" ]; then
              dryrun="1"
            else
              args+=("$arg")
            fi
            ;;
        
        -s|--silent)
            if [ -z "$endofoptions" = "0" ]; then
              silent="1"
            else
              args+=("$arg")
            fi
            ;;
        
        
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1"  
            else
              args+=("$arg")
            fi
            ;;
                
        -*)
            if [ -z "$endofoptions" ]; then
              args+=("$arg")
            else
              echo "ERROR: Unknown option $arg" >&2
              show_usage
              exit 123
            fi
            ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
done

# Valideer aantal argumenten
if [ "${#args[@]}" -lt 2 ]; then
    echo "ERROR: Need at least text and n" >&2
    show_usage
    exit 1
fi

if [ "${#args[@]}" -gt 2 ]; then
    echo "ERROR: Too many arguments" >&2
    show_usage
    exit 1
fi

RIGHT "${args[@]}"
exit $?
