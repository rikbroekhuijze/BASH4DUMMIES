#!/bin/bash

VERSION="0.5"
MYBASENAME=$(basename "$0")

show_usage() {
    cat << EOF

Usage: $MYBASENAME <text> [characters] [position]

Removes specified characters from the left, right, or both sides of a text string.
By default, whitespace characters are removed (space, tab, newline, carriage return).

Parameters:
  text        - The string to be chopped
  characters  - Optional: which characters to remove (default: whitespace)
  position    - Optional: 0=both sides (default), 1=left only, 2=right only

Examples:
  $MYBASENAME "   hello world   "
  $MYBASENAME "'hello world'" "'"
  echo "   test   " | $MYBASENAME
  $MYBASENAME "---hello---" "-" 2          # remove only from the right
  $MYBASENAME "   hello   " "" 2           # remove default whitespace, right side only

Options:
  -h, --help     Show this help message
  -v, --version  Show version information

EOF
}

# Stel default karakters in (whitespace)
DEFAULT_CHARS=$' \t\n\r'

# Verwerk de argumenten
args=()

# Check voor pipe input
if [ ! -t 0 ]; then
    # Lees alle regels van stdin
    stdin_content=""
    while IFS= read -r line; do
        if [ -z "$stdin_content" ]; then
            stdin_content="$line"
        else
            stdin_content="$stdin_content"$'\n'"$line"
        fi
    done
    args+=("$stdin_content")
fi

for arg in "$@"; do
    case "$arg" in
        -h|--help)
            show_usage
            exit 0
            ;;
        -v|--version)
            echo "$VERSION"
            exit 0
            ;;
        *)
            args+=("$arg")
            ;;
    esac
done

# Controleer aantal argumenten
if [ "${#args[@]}" -lt 1 ]; then
    echo >&2
    echo "FOUT! Geef minstens een tekst om te chopen." >&2
    show_usage
    exit 123
fi

if [ "${#args[@]}" -gt 3 ]; then
    echo >&2
    echo "FOUT! Te veel argumenten." >&2
    show_usage
    exit 123
fi

x="${args[0]}"
y="${args[1]:-$DEFAULT_CHARS}"  # Als y leeg is, gebruik default whitespace
z="${args[2]:-0}"                # Als z leeg is, gebruik 0

# Valideer z
if ! [[ "$z" =~ ^[012]$ ]]; then
    echo "FOUT! positie moet 0, 1 of 2 zijn." >&2
    show_usage
    exit 123
fi

# CHOP functie
chop() {
    local string="$1"
    local chars="$2"
    local mode="$3"
    
    # Chop links (mode 0 of 1)
    if [ "$mode" = "0" ] || [ "$mode" = "1" ]; then
        while true; do
            # Als string leeg is, stoppen
            [ -z "$string" ] && break
            
            # Check of eerste karakter in chars zit
            first_char="${string:0:1}"
            if [[ "$chars" == *"$first_char"* ]]; then
                string="${string:1}"
            else
                break
            fi
        done
    fi
    
    # Chop rechts (mode 0 of 2)
    if [ "$mode" = "0" ] || [ "$mode" = "2" ]; then
        while true; do
            # Als string leeg is, stoppen
            [ -z "$string" ] && break
            
            # Check of laatste karakter in chars zit
            last_char="${string: -1}"
            if [[ "$chars" == *"$last_char"* ]]; then
                string="${string%?}"
            else
                break
            fi
        done
    fi
    
    echo -n "$string"
}

# Voer CHOP uit
chop "$x" "$y" "$z"
echo  # Extra newline
