#!/bin/bash

VERSION="0.20"
MYBASENAME=$(basename "$0")

show_usage() {
    cat << EOF

Usage: $MYBASENAME <text> [characters] [position]

Removes specified characters from the left, right, or both sides of a text string.
By default, whitespace characters are removed (space, tab, newline, carriage return).

Parameters:
  text        - The string to be chopped (can be passed via pipe)
  characters  - Optional: which characters to remove (default: whitespace)
  position    - Optional: 0=both sides (default), 1=left only, 2=right only

Examples:
  $MYBASENAME "   hello world   "
  $MYBASENAME "'hello world'" "'"
  echo "   test   " | $MYBASENAME
  $MYBASENAME "---hello---" "-" 2          # remove only from the right
  $MYBASENAME "   hello   " "" 2           # remove default whitespace, right side only
  $MYBASENAME "abcabcdefghighi" "abcghi"   # => def
  
  
  # Remove only spaces, keep newlines
  $MYBASENAME "  hello 
  world  " " "

Options:
  -h, --help     Show this help message
  -v, --version  Show version information

EOF
}

# Stel default karakters in (whitespace)
DEFAULT_CHARS=$' \t\n\r'

# CHOP functie - schrijft DIRECT naar stdout
chop() {
    
    local string="$1"
    local chop_characters="$2"
    local mode="${3:-0}"
    local line
    
    string2="$string"
    
    # Valideer mode
    if ! [[ "$mode" =~ ^[012]$ ]]; then
      echo "ERROR! Position must be 0, 1, or 2." >&2
      show_usage
      exit 123
    fi
    
    # echo "debug : $debug"
    if [ ! -z "$debug" ] ; then
      echo
      echo "string : $string"
      echo -n "chop_characters in ascii : "
      echo "$chop_characters" | ASC
      
    fi
    
    if [ "$mode" = "0" ] || [ "$mode" = "1" ]; then
    
      for (( abc=0; abc<${#string}; abc++ )); do
      
        char="${string:$abc:1}"
        
        for (( bcd=0; bcd<${#chop_characters}; bcd++ )); do
          toggle=""
          chop_char="${chop_characters:$bcd:1}"
          if [ "$char" = "$chop_char" ]; then
            string2="${string2:1}"
            toggle="1"
            break
          fi
        done
      
        if [ -z "$toggle" ] ; then
          break
        fi
      
      done
    fi
    
    string="$string2"
    
    if [ "$mode" = "0" ] || [ "$mode" = "2" ]; then
    
      for (( abc=${#string}-1; abc>=0; abc-- )); do
      
        char="${string:$abc:1}"
        
        for (( bcd=0; bcd<${#chop_characters}; bcd++ )); do
          toggle=""
          chop_char="${chop_characters:$bcd:1}"
          if [ "$char" = "$chop_char" ]; then
            string2="${string2%?}"
            toggle="1"
            break
          fi
        done
      
        if [ -z "$toggle" ] ; then
          break
        fi
      
      done
    fi
    
    echo $string2
    
}

# MAIN 
args=()

# Check voor pipe input
if [ ! -t 0 ]; then
    stdin_content=$(cat; echo bla)
    if [ "${#stdin_content}" -gt "3" ] ;then
      stdin_content="${stdin_content::-4}"
      if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
      fi
    fi
fi

debug=""
verbose=""
dryrun=""
silent=""
endofoptions=""
for arg in "$@"; do
    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
           
        -d|--debug)
            if [ -z "$endofoptions" ]; then
              debug="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --verbose)
            if [ -z "$endofoptions" ]; then
              verbose="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --dryrun)
            if [ -z "$endofoptions" ]; then
              dryrun="1"
            else
              args+=("$arg")
            fi
            ;;
        
        -s|--silent)
            if [ -z "$endofoptions" = "0" ]; then
              silent="1"
            else
              args+=("$arg")
            fi
            ;;
        
        
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1"  
            else
              args+=("$arg")
            fi
            ;;
                
        -*)
            if [ -z "$endofoptions" ]; then
              args+=("$arg")
            else
              echo "ERROR: Unknown option $arg" >&2
              show_usage
              exit 123
            fi
            ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
done


# Controleer aantal argumenten
if [ "${#args[@]}" -lt 1 ]; then
    echo >&2
    echo "ERROR! Need at least text to chop." >&2
    show_usage
    exit 123
fi

if [ "${#args[@]}" -gt 3 ]; then
    echo >&2
    echo "ERROR! Too many arguments." >&2
    show_usage
    exit 123
fi

# Debug: toon args (uitcommentarieer voor testen)
if [ ! -z "$debug" ] ; then
  echo
  echo "args: ${#args[@]}" >&2
  for i in "${!args[@]}"; do
     echo "  $i : =>${args[i]}<=" >&2
  done
fi

# DIRECTE OUTPUT - chop schrijft zelf naar stdout
# chop "$x" "$y" "$z"

chop "${args[@]}"

# Geen extra newline - chop heeft al de juiste newlines toegevoegd
exit $?
