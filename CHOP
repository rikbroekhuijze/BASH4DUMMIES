#!/bin/bash

VERSION="0.20.15"
MYBASENAME=$(basename "$0")

char1=$'\x01'
char2=$'\x02'
char3=$'\x03'
stopper="${char1}${char2}${char3}${char2}${char1}"

show_usage() {
    cat << EOF

Usage: $MYBASENAME <text> [characters] [position]

Removes specified characters from the left, right, or both sides of a text string.
By default, whitespace characters are removed (space, tab, newline, carriage return).

Parameters:
  text        - The string to be chopped (can be passed via pipe)
  characters  - Optional: which characters to remove (default: whitespace)
  position    - Optional: 0=both sides (default), 1=left only, 2=right only

Examples:
  $MYBASENAME "   hello world   "         # hello world
  $MYBASENAME "'hello world'" "'"         # hello world
  echo "   test   " | $MYBASENAME         # test
  $MYBASENAME "---hello---" "o-l" 2       # remove o,-,l only from the right => ---he
  $MYBASENAME "   hello   " "" 2          # remove default chars, right side only
  $MYBASENAME "abcabcdefghighi" "abcghi"  # => def
  
  
  # Remove only spaces, keep newlines
  $MYBASENAME "  hello world              # => 'hello world
      " " "                        # => '

Options:
  -h, --help           Show this help message
  -v, --version        Show version information
  
  in case you want --help, --version or -- itself as an argument:
  --                   End of options 
          
;°)
  
EOF
}

# check only voor verbose & debug first.
verbose=""
debug=""
for arg in "$@"; do
    [ "$arg" = "--" ] && break
    if [ "$arg" = "--verbose" ]; then
        verbose=1
        break
    fi
    if [ "$arg" = "--debug" ]; then
        set -x
        break
    fi
done

# Stel default karakters in (whitespace)
DEFAULT_CHARS=$' \t\n\r'

# CHOP functie - schrijft DIRECT naar stdout
chop() {
    
    local string="$1"
    local chop_characters="${2:-$DEFAULT_CHARS}"
    local mode="${3:-0}"
    local line
    
    string2="$string"
    
    # Valideer mode
    if ! [[ "$mode" =~ ^[012]$ ]]; then
      echo "$MYBASENAME: Position must be 0, 1, or 2." >&2
      exit 123
    fi
    
    # echo "debug : $debug"
    if [ ! -z "$debug" ] ; then
      echo
      echo "string : $string"
      echo -n "chop_characters in ascii : "
      echo "$chop_characters" | ASC
      
    fi
    
    if [ "$mode" = "0" ] || [ "$mode" = "1" ]; then
    
      for (( abc=0; abc<${#string}; abc++ )); do
      
        char="${string:$abc:1}"
        
        for (( bcd=0; bcd<${#chop_characters}; bcd++ )); do
          toggle=""
          chop_char="${chop_characters:$bcd:1}"
          if [ "$char" = "$chop_char" ]; then
            string2="${string2:1}"
            toggle="1"
            break
          fi
        done
      
        if [ -z "$toggle" ] ; then
          break
        fi
      
      done
    fi
    
    string="$string2"
    
    if [ "$mode" = "0" ] || [ "$mode" = "2" ]; then
    
      for (( abc=${#string}-1; abc>=0; abc-- )); do
      
        char="${string:$abc:1}"
        
        for (( bcd=0; bcd<${#chop_characters}; bcd++ )); do
          toggle=""
          chop_char="${chop_characters:$bcd:1}"
          if [ "$char" = "$chop_char" ]; then
            string2="${string2%?}"
            toggle="1"
            break
          fi
        done
      
        if [ -z "$toggle" ] ; then
          break
        fi
      
      done
    fi
    
    # Alleen als er output was
    if [ ! -z "$string2" ] ; then
      echo "$string2"
    fi
    
}

# MAIN 
args=()

#
# Check voor pipe input
if IFS='' read -t 0.01 -r -n 1 eerste_karakter; then
    # Er is daadwerkelijk data. Lees de rest, voeg de marker toe en knip 'm er weer af. (grab the newline)
    rest=$(cat; echo "$stopper")
    stdin_content="${eerste_karakter}${rest}"
    # Verwijder marker + eventuele newline
    stdin_content="${stdin_content%$stopper}"
    stdin_content="${stdin_content%$'\n'}"
    # we willen "" ook vangen.
    # if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    # fi
# else
  # # pipe or file
  # # bacon (en anderen) openen een pipe intern. beiden (-p en -f ) reageren daarop.
  # if [ -p /dev/stdin ] || [ -f /dev/stdin ] ; then
  #   stdin_content=$(cat; echo "$stopper")
  #   stdin_content="${stdin_content%$stopper}"
  #   stdin_content="${stdin_content%$'\n'}"
  #   # we willen "" ook vangen.
  #   # if [ -n "$stdin_content" ]; then
  #       args+=("$stdin_content")
  #   # fi
 #  fi
fi

[ -n "$verbose" ] && echo
endofoptions=""
for arg in "$@"; do
   
    [ -n "$verbose" ] && echo "arg : $arg"
    
    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--verbose|-d|--debug)
        
           if NOT ISNULL "$endofoptions"; then args+=("$arg") ; fi
           ;;
            
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1" 
              endofoptionstoggle="1"
            else
              args+=("$arg")
            fi
            ;;
                
    #    -*)
    #        # what about a megative number ?
    #        if [ -z "$endofoptions" ]; then
    #          args+=("$arg")
    #        else
    #          echo "$MYBASENAME: Unknown option $arg" >&2
    #          exit 123
    #        fi
    #        ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
    
done

# Controleer aantal argumenten
if [ "${#args[@]}" -lt 1 ]; then
    exit 0
fi

if [ "${#args[@]}" -gt 3 ]; then
    echo >&2
    echo "$MYBASENAME: Too many arguments." >&2
    # show_usage
    exit 123
fi

# Debug: toon args (uitcommentarieer voor testen)
if [ ! -z "$debug" ] ; then
  echo
  echo "args: ${#args[@]}" >&2
  for i in "${!args[@]}"; do
     echo "  $i : =>${args[i]}<=" >&2
  done
fi

chop "${args[@]}"
exit $?
