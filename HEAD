#!/bin/bash

VERSION="0.20.13"
MYBASENAME=$(basename "$0")
SCRIPTNAME="$MYBASENAME"

char1=$'\x01'
char2=$'\x02'
char3=$'\x03'
stopper="${char1}${char2}${char3}${char2}${char1}"

show_usage() {
    cat << EOF

Usage: $MYBASENAME <text> <amount> [<delimiter>]

Returns the first amount of  tokens from a text string.
If amount is negative, returns all but the last amount of tokens.

Parameters:
  text        - The string to extract from (can be passed via pipe)
  amount      - Number of tokens to take:                 
                 positive: take first n tokens
                 negative: remove last n tokens
  delimiter   - Optional: character(s) that separate tokens (default: space)

Examples:
  $MYBASENAME "een twee drie vier" 2         # -> een twee (default space)
  $MYBASENAME "een twee drie vier" -2        # -> een twee (remove last 2)
  $MYBASENAME "a,b,c,d,e" 3 ','              # -> a,b,c
  $MYBASENAME "a,b,c,d,e" -2 ','             # -> a,b,c
  echo "one two three" | $MYBASENAME 2       # -> one two
  
  # Extract tokens from multi-line text
  echo "one two three
four five six
seven eight nine
ten"  | $MYBASENAME -3 $'\n'                 # -> one two three

Options:
  -h, --help           Show this help message
  -v, --version        Show version information
  
  in case you want --help, --version or -- itself as an argument:
  --                   End of options 
          
;°)
  
EOF
}

# check only voor verbose & debug first.
verbose=""
debug=""
for arg in "$@"; do
    [ "$arg" = "--" ] && break
    [ "$arg" = "--verbose" ] && verbose=1
    [ "$arg" = "--debug" ] && set -x
done

# Cross-platform versie (werkt ook op macOS)
if command -v readlink >/dev/null 2>&1 && readlink -f . >/dev/null 2>&1; then
    SCRIPTPATH="$(readlink -f "${BASH_SOURCE[0]}")"
else
    # Fallback voor macOS (gebruik cd + pwd truc)
    SCRIPTPATH="$( cd "$(dirname "${BASH_SOURCE[0]}")" && pwd )/$(basename "${BASH_SOURCE[0]}")"
fi

SCRIPTDIR="$(dirname "$SCRIPTPATH")"
if [ "$(basename "$SCRIPTDIR")" = "BIN" ] ||  [ "$(basename "$SCRIPTDIR")" = "SRC" ] || [ "$(basename "$SCRIPTDIR")" = "MUSEUM" ] ; then
  DIRECTORY="$(dirname "$SCRIPTDIR")"
else
  DIRECTORY="$SCRIPTDIR"
fi

MAPFILE() {
    
    # Gebruik:
    # haystack="-1--test-3-"
    # delimiter="--"
    # MAPFILE "$haystack" "$delimiter" "fields" 
    # for (( i=0; i<${#fields[@]}; i++ )); do
    #     echo "$i : '${fields[$i]}'"
    # done
    
    # Check of er een array naam is meegegeven
    if [[ -z "$3" ]]; then
        echo "MYBASENAME: ERROR in function ${0##*/}: No array name given." >&2
        exit 123
    fi
    
    local string="$1"
    local delimiter="$2"
    local -n output_array="$3"  # nameref naar array
    
    [ -n "$verbose" ] && echo 
    [ -n "$verbose" ] && echo "function MAPFILE"
    [ -n "$verbose" ] && echo 
    [ -n "$verbose" ] && echo "string : $string"
    [ -n "$verbose" ] && echo "delimiter : =>$delimiter<="
    [ -n "$verbose" ] && echo "output_array : $output_array"
    
    output_array=()
    local current=""
    local abc=0
    local dlen=${#delimiter}
    local slen=${#string}
    local bcd=1  # start op index 1
    
    while [[ $abc -lt $slen ]]; do
        # Check if we have delimiter at position i
        if [[ "${string:$abc:$dlen}" == "$delimiter" ]]; then
            output_array["$bcd"]="$current"
            current=""
            ((abc += dlen))
            ((bcd++))
        else
            current+="${string:$abc:1}"
            ((abc++))
        fi
    done

    output_array["$bcd"]="$current"
    ((bcd++))
    
    [ -n "$verbose" ] && echo 
    [ -n "$verbose" ] && echo "aantal : ${#output_array[@]}" 
    if [ -n "$verbose" ] ; then
      for (( abc=1; abc<=${#output_array[@]}; abc++ )); do
        echo "$abc : '${output_array[$abc]}'"
      done
    fi
   
}

HEAD() {
    
    local haystack="$1"
    local amount="$2"
    local delimiter="${3:- }"
    local result=""
    local stopnumber
    local last
    
    if [[ "$haystack" = "" ]]; then
      return 0
    fi
    
    if [ -n "$verbose" ]; then
      echo
      echo "verbose : $verbose"
      echo "haystack : $haystack " 
      echo "amount : $amount"  
      echo "delimiter : =>$delimiter<=" 
      echo
    fi
    
    # Validatie: amount moet een getal zijn
    if [[ ! "$amount" =~ ^-?[0-9]+$ ]]; then
        echo "$MYBASENAME: amount must be an integer" >&2
        return 123
    fi
    
    if [[ "$amount" -eq 0 ]]; then
      return 0
    fi
    
    # Split de string op delimiter
    MAPFILE "$haystack" "$delimiter" "fields"
    
    last=${#fields[@]}
    
    # Bereken start stop
    if [ "$amount" -gt 0 ]; then
        stopnumber=$amount
    else
        stopnumber=$((last + amount))
    fi
    
    [ -n "$verbose" ] && echo "stopnumber : $stopnumber"
    
    abc=1
    string=""
    while [ $abc -le "$stopnumber" ]; do
      
      [ -n "$verbose" ] && echo
      [ -n "$verbose" ] && echo "$abc : ${fields[abc]}"
      [ -n "$verbose" ] && echo "string b4 : $string"
      
      if [ "$string" = "" ] ; then
        if [ "${fields[abc]}" = ""  ] ; then
          if [ "$abc" = "1" ] ; then
            :
          else
            string=" "
          fi
        else
          #string=${fields[abc]}
          string="${string}${delimiter}${fields[abc]}"
        fi
      else
        string="${string}${delimiter}${fields[abc]}"
      fi
      
      [ -n "$verbose" ] && echo "string 8r : $string"
      
      ((abc++))
      
    done
    
    if  [ -n "$verbose" ]; then
      echo
    fi
    
    if [[ ! -z "$string" ]]; then
      echo "$string"
    fi
    
    return 0
    
}

# MAIN 
args=()

# Check voor pipe input
if IFS='' read -t 0.01 -r -n 1 eerste_karakter; then
    # Er is daadwerkelijk data. Lees de rest, voeg de marker toe en knip 'm er weer af. (grab the newline)
    rest=$(cat; echo "$stopper")
    stdin_content="${eerste_karakter}${rest}"
    # Verwijder marker + eventuele newline
    stdin_content="${stdin_content%$stopper}"
    stdin_content="${stdin_content%$'\n'}"
    # we willen "" ook vangen.
    # if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    # fi
# else
  # # pipe or file
  # # bacon (en anderen) openen een pipe intern. beiden (-p en -f ) reageren daarop.
  # if [ -p /dev/stdin ] || [ -f /dev/stdin ] ; then
  #   stdin_content=$(cat; echo "$stopper")
  #   stdin_content="${stdin_content%$stopper}"
  #   stdin_content="${stdin_content%$'\n'}"
  #   # we willen "" ook vangen.
  #   # if [ -n "$stdin_content" ]; then
  #       args+=("$stdin_content")
  #   # fi
  # fi
  
fi

[ -n "$verbose" ] && echo
endofoptions=""
for arg in "$@"; do
   
    [ -n "$verbose" ] && echo "arg : $arg"
    
    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--verbose|-d|--debug)
        
           if [ -n "$endofoptions" ]; then 
             args+=("$arg") 
           fi
           
           ;;
        
        --dryrun)
            if [ -z "$endofoptions" ]; then
              dryrun=1
            else   
              args+=("$arg")
            fi
            ;;
            
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1" 
              endofoptionstoggle="1"
            else
              args+=("$arg")
            fi
            ;;
                
    #    -*)
    #        # what about a megative number ?
    #        if [ -z "$endofoptions" ]; then
    #          args+=("$arg")
    #        else
    #          echo "$MYBASENAME: Unknown option $arg" >&2
    #          exit 123
    #        fi
    #        ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
    
done

if [ -n "$verbose" ] ; then
  echo
  echo "number of arguments : ${#args[@]}"
  echo "stdin_content : =>$stdin_content<="
  for ((abc=0; abc<${#args[@]}; abc++)); do
    echo "argument $abc : =>${args[$((abc))]}<="
  done
  echo
fi

# Valideer aantal argumenten
if [ "${#args[@]}" -lt 2 ]; then
    echo "$MYBASENAME: Need at least text and amount" >&2
    exit 123
fi

if [ "${#args[@]}" -gt 3 ]; then
    echo "$MYBASENAME: Too many arguments" >&2
    exit 1
fi

HEAD "${args[@]}"
exit $?
