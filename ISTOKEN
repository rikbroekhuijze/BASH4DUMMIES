#!/bin/bash

VERSION="0.20.5"
MYBASENAME=$(basename "$0")

char1=$'\x01'
char2=$'\x02'
char3=$'\x03'
stopper="${char1}${char2}${char3}${char2}${char1}"

all=0
endofoptions="0"

show_usage() {
    cat << EOF

Usage: $MYBASENAME <string> <token> [<delimiter>] [<position>]

Verifies if a token occurs in a delimited string, optionally starting from <position>.
print the index of the found token
Returns 0 (true) if found, 1 (false) if not.

Parameters:
  string      - The string to search in (can be passed via pipe)
  token       - The token to look for
  delimiter   - Optional: character(s) that separate tokens (default: space)
  position    - Optional: if given, checks if token is at exact position (1-based)

Examples:
  $MYBASENAME "one two three" "two"              # -> true (0)
  $MYBASENAME "one two three" "four"             # -> false (1)
  $MYBASENAME "a,b,c,d" "c" ','                  # -> true
  $MYBASENAME "a,b,c,d" "c" ',' 3                # -> true (at position 3)
  $MYBASENAME "a,b,c,d" "c" ',' 2                # -> false (not at pos 2)
  echo "one two three" | $MYBASENAME "two"       # -> true

Options:
  -h, --help     Show this help message
  -v, --version  Show version information

EOF
}

ISTOKEN() {
    
    local string="$1"
    local token="$2"
    local delimiter="${3:- }"
    local startposition="${4:-1}"
    local tokens=()
    
    if  [[ "$debug" = "1" ]]; then
      echo 
      echo "string : =>$string<="
      echo "token : =>$token<="
      echo "delimiter : =>$delimiter<="
      echo "startposition : =>$startposition<="
    fi

    # Validatie
    if [ -z "$string" ] || [ -z "$token" ]; then
        return 1
    fi

    if [[ ! "$startposition" =~ ^[0-9]+$ ]]; then
      echo "startposition must be an integer." >&2
      exit 123
    fi

    if [[ "$startposition" = "0" ]]; then
      all="1"
      startposition="1"
    fi

    # Split de string op delimiter (zelfde truc als HEAD/TAIL)
    mapfile -d "$delimiter" -O 1 -t fields <<< "$string""$stopper"
    
    # Na het splitten, 
    if [ "${#fields[@]}" -gt 0 ]; then
      last="${#fields[@]}"
      fields["$last"]="${fields[$last]%$'\n'}"
      fields["$last"]="${fields[$last]%$stopper}"
    fi
        
    # Anders zoek in alle tokens
    for ((abc="$startposition"; abc<=${#fields[@]}; abc++)); do
    
      if [ "${fields[$abc]}" = "$token" ]; then
        echo  "$abc"
        exit 0
      fi
    done
    
    return 1
    
}

# MAIN 
args=()

# Check voor pipe input
# Vervang de hele check door dit blok
if read -t 0.01 -r -n 1 eerste_karakter; then
    # Er is daadwerkelijk data. Lees de rest, voeg de marker toe en knip 'm er weer af.
    rest=$(cat; echo "$stopper")
    stdin_content="${eerste_karakter}${rest}"
    # Verwijder marker + eventuele newline
    stdin_content="${stdin_content%$stopper}"
    stdin_content="${stdin_content%$'\n'}"
    # we willen "" ook vangen.
    # if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    # fi
fi

debug=""
verbose=""
dryrun=""
silent=""
endofoptions=""
for arg in "$@"; do
    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
           
        -d|--debug)
            if [ -z "$endofoptions" ]; then
              debug="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --verbose)
            if [ -z "$endofoptions" ]; then
              verbose="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --dryrun)
            if [ -z "$endofoptions" ]; then
              dryrun="1"
            else
              args+=("$arg")
            fi
            ;;
        
        -s|--silent)
            if [ -z "$endofoptions"]; then
              silent="1"
            else
              args+=("$arg")
            fi
            ;;
        
        
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1"  
            else
              args+=("$arg")
            fi
            ;;
                
        -*)
            if [ -z "$endofoptions" ]; then
              args+=("$arg")
            else
              echo "ERROR: Unknown option $arg" >&2
              show_usage
              exit 123
            fi
            ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
done

# Check bash versie (mapfile bestaat sinds bash 4.0)
if [ "${BASH_VERSINFO[0]}" -lt 4 ]; then
  echo "Warning: Your bash version is ${BASH_VERSINFO[0]}.${BASH_VERSINFO[1]}" >&2
  echo "mapfile needs bash 4.0 or higher. Upgrade bash for full support." >&2
  exit 123
fi

# Valideer aantal argumenten
if [ "${#args[@]}" -lt 2 ]; then
    echo "ERROR: Need at least string and token" >&2
    show_usage
    exit 1
fi

if [ "${#args[@]}" -gt 4 ]; then
    echo "ERROR: Too many arguments" >&2
    show_usage
    exit 1
fi

# Roep ISTOKEN aan
ISTOKEN "${args[@]}"
exit $?
