#!/bin/bash

VERSION="0.20.7"
MYBASENAME=$(basename "$0")

char1=$'\x01'
char2=$'\x02'
char3=$'\x03'
stopper="${char1}${char2}${char3}${char2}${char1}"

show_usage() {
    cat << EOF

Usage: $MYBASENAME [<string>] [<delimiter>]

Returns the ASCII/Unicode values of all characters.
If no string argument is given, reads from stdin.

Parameters:
  string      - Optional: string to convert (reads from stdin if omitted)
  delimiter   - Optional: character(s) to place between values (default: space)

Examples:
  $MYBASENAME "abc"              # -> 97 98 99 (space separated)
  $MYBASENAME "abc" ','          # -> 97,98,99 (comma separated)
  echo "Hello" | $MYBASENAME ' ' # -> 72 101 108 108 111
  $MYBASENAME $'a\nb'            # -> 97 10 98

Options:
  -h, --help           Show this help message
  -v, --version        Show version information
  
  in case you want --help, --version or -- itself as an argument:
  --                   End of options 
          
;°)
  
EOF
}

ASC() {
    local input="$1"
    local delimiter="${2:-$' '}"
    local char=""
    local i
    local first=1
    
    # Loop door alle karakters
    for ((i=0; i<${#input}; i++)); do
        char="${input:$i:1}"
        if [ $first -eq 1 ]; then
            printf "%d" "'$char"
            first=0
        else
            printf "%s%d" "$delimiter" "'$char"
        fi
    done
    
    # Alleen een newline aan het einde als er output was
    if [ $first -eq 0 ]; then
        echo
    fi
}

# MAIN 
args=()

#
# Check voor pipe input
if read -t 0.01 -r -n 1 eerste_karakter; then
    # Er is daadwerkelijk data. Lees de rest, voeg de marker toe en knip 'm er weer af. (grab the newline)
    rest=$(cat; echo "$stopper")
    stdin_content="${eerste_karakter}${rest}"
    # Verwijder marker + eventuele newline
    stdin_content="${stdin_content%$stopper}"
    stdin_content="${stdin_content%$'\n'}"
    # we willen "" ook vangen.
    # if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    # fi
# else
  # # pipe or file
  # # bacon (en anderen) openen een pipe intern. beiden (-p en -f ) reageren daarop.
  # if [ -p /dev/stdin ] || [ -f /dev/stdin ] ; then
  #   stdin_content=$(cat; echo "$stopper")
  #   stdin_content="${stdin_content%$stopper}"
  #   stdin_content="${stdin_content%$'\n'}"
  #   # we willen "" ook vangen.
  #   # if [ -n "$stdin_content" ]; then
  #       args+=("$stdin_content")
  #   # fi
 #  fi
fi

debug=""
endofoptions=""
for arg in "$@"; do

    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
           
        -d|--debug)
            if [ -z "$endofoptions" ]; then
              debug="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1" 
              endofoptionstoggle="1"
            else
              args+=("$arg")
            fi
            ;;
                
    #    -*)
    #        # what about a megative number ?
    #        if [ -z "$endofoptions" ]; then
    #          args+=("$arg")
    #        else
    #          echo "$MYBASENAME: Unknown option $arg" >&2
    #          exit 123
    #        fi
    #        ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
    
done

# Valideer aantal argumenten
if [ "${#args[@]}" -gt 2 ]; then
    echo >&2
    echo "$MYBASENAME: Too many arguments" >&2
    # show_usage
    exit 123
fi

if [ "${#args[@]}" -lt 1 ]; then
    exit 0
fi

ASC "${args[@]}"
exit $?
