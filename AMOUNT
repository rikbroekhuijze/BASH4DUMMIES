#!/bin/bash

VERSION="0.20.4"
MYBASENAME=$(basename "$0")

show_usage() {
    cat << EOF

Usage: $MYBASENAME <text> <needle> [<delimiter>]

Counts how many times a <needle> or <word> occurs in <text>.

Parameters:
  text        - The string to search in (can be passed via pipe)
  needle      - What to count
  delimiter   - Optional: if given, splits <text> into fields/words first

Examples:
  $MYBASENAME "bla bla bla" "bla"           # -> 3 (all occurrences)
  $MYBASENAME "bla bla bla" "bla" " "       # -> 3 (all three words are "bla")
  $MYBASENAME "blabla bla bla" "bla"        # -> 4 (all occurrences)
  $MYBASENAME "blabla bla bla" "bla" " "    # -> 2 (only whole words)
  echo "a,b,c,a,b,c" | $MYBASENAME "a"      # -> 2 (all occurrences)
  echo "a,b,c,a,b,c" | $MYBASENAME "a" ','  # -> 2 (only whole fields)
  echo "a,b,c,aa,b,c" | $MYBASENAME "a"     # -> 3 (all occurrences)
  echo "a,b,c,aa,b,c" | $MYBASENAME "a" ',' # -> 1 (only whole fields)

Options:
  -h, --help     Show this help message
  -v, --version  Show version information

EOF
}

AMOUNT() {
    
    local haystack="$1"
    local needle="$2"
    local delimiter="${3:-}"
    local count=0
    
    if [ -z "$debug" ]; then
      echo 
      echo haystackhaystack
      echo needleneedle
      echo delimiterdelimiter
      
    
    if [ -z "$delimiter" ]; then
        # Tel ALLE voorkomens van substring
        local temp="$haystack"
        while [[ "$temp" == *"$needle"* ]]; do
            ((count++))
            temp="${temp#*"$needle"}"
        done
    else
      
        mapfile -d "$delimiter" -t fields <<< "$haystack""bla"
        
        # Na het splitten, 
        if [ "${#fields[@]}" -gt 0 ]; then
          last=${#fields[@]}-1
          if [ "${fields[$last]: -3}" = "bla" ]; then
            fields[$last]="${fields[$last]%???}"  # Verwijder laatste 3 karakters
          else
            fields[$last]="${fields[$last]%????}"  # Verwijder laatste 4 karakters
          fi
        fi
        
        counter="0"
        # Tel hoe vaak needle voorkomt als heel veld
        for field in "${fields[@]}"; do
            if [ "$field" = "$needle" ]; then
                ((count++))
            fi
        done
    fi
    
    echo "$count"
}

# MAIN 
args=()

# Check voor pipe input
if [ ! -t 0 ]; then
    stdin_content=$(cat; echo bla)
    if [ "${#stdin_content}" -gt "3" ] ;then
      stdin_content="${stdin_content::-4}"
      if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
      fi
    fi
fi

debug=""
verbose=""
dryrun=""
silent=""
endofoptions=""
for arg in "$@"; do
    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
           
        -d|--debug)
            if [ -z "$endofoptions" ]; then
              debug="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --verbose)
            if [ -z "$endofoptions" ]; then
              verbose="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --dryrun)
            if [ -z "$endofoptions" ]; then
              dryrun="1"
            else
              args+=("$arg")
            fi
            ;;
        
        -s|--silent)
            if [ -z "$endofoptions" = "0" ]; then
              silent="1"
            else
              args+=("$arg")
            fi
            ;;
        
        
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1"  
            else
              args+=("$arg")
            fi
            ;;
                
        -*)
            if [ -z "$endofoptions" ]; then
              args+=("$arg")
            else
              echo "ERROR: Unknown option $arg" >&2
              show_usage
              exit 123
            fi
            ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
done

# Valideer aantal argumenten
if [ "${#args[@]}" -lt 2 ]; then
    echo "ERROR: Need at least haystack and needle" >&2
    # show_usage
    exit 123
fi

if [ "${#args[@]}" -gt 3 ]; then
    echo "ERROR: Too many arguments" >&2
    # show_usage
    exit 123
fi

AMOUNT "${args[@]}"
exit $?
