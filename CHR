#!/bin/bash

VERSION="0.4"
MYBASENAME=$(basename "$0")

show_usage() {
    cat << EOF

Usage: $MYBASENAME <number> [<number> ...]

Returns the ASCII character(s) for given value(s).
If no arguments are given, reads numbers from stdin (space-separated).
If both stdin and arguments are given, all numbers are combined.

Examples:
  $MYBASENAME 97                    # -> a
  $MYBASENAME 10                    # -> (newline)
  $MYBASENAME 65 66 67              # -> ABC
  echo "72 101 108" | $MYBASENAME   # -> Hel
  echo "98 108 97" | $MYBASENAME 98 108 97  # -> blabla

Options:
  -h, --help     Show this help message
  -v, --version  Show version information

EOF
}

CHR() {
    local all_values=()
    local result=""
    local num
    
    # Verzamel getallen van stdin (als die er is)
    if [ -n "$STDIN_CONTENT" ]; then
        # Split de stdin string op spaties
        IFS=' ' read -ra stdin_values <<< "$STDIN_CONTENT"
        all_values+=("${stdin_values[@]}")
    fi
    
    # Voeg command line argumenten toe
    for arg in "$@"; do
        all_values+=("$arg")
    done
    
    # Verwerk alle getallen
    for num in "${all_values[@]}"; do
        # Validatie: moet een getal zijn tussen 0-255
        if [[ ! "$num" =~ ^[0-9]+$ ]] || [ "$num" -lt 0 ] || [ "$num" -gt 255 ]; then
            echo "ERROR: '$num' is not a valid ASCII value (0-255)" >&2
            return 1
        fi
        
        # Converteer nummer naar karakter
        printf -v char "\\x$(printf "%x" "$num")"
        result+="$char"
    done
    
    # Output het resultaat
    printf "%s" "$result"
}

# MAIN 
STDIN_CONTENT=""
args=()

# Check voor pipe input
if [ ! -t 0 ]; then
    # Lees ALLE stdin met de bewezen methode
    STDIN_CONTENT=$(cat; echo bla)
    STDIN_CONTENT="${STDIN_CONTENT::-4}"
fi

# Verwerk argumenten
for arg in "$@"; do
    case "$arg" in
        -h|--help)
            show_usage
            exit 0
            ;;
        -v|--version)
            echo "$VERSION"
            exit 0
            ;;
        *)
            args+=("$arg")
            ;;
    esac
done

# Roep CHR aan
if [ -n "$STDIN_CONTENT" ] || [ ${#args[@]} -gt 0 ]; then
    CHR "${args[@]}"
    echo  # Newline voor de prompt
else
    echo "ERROR: Need at least one number" >&2
    show_usage
    exit 1
fi
exit $?
