#!/bin/bash

VERSION="0.20.2"
MYBASENAME=$(basename "$0")

char1=$'\x01'
char2=$'\x02'
char3=$'\x03'
stopper="${char1}${char2}${char3}${char2}${char1}"

show_usage() {
    cat << EOF

Usage: $MYBASENAME <text> [<delimiter>]

Reverses a string. If delimiter is given, reverses tokens instead of characters.

Parameters:
  text        - The string to reverse (can be passed via pipe)
  delimiter   - Optional: if given, split into tokens and reverse their order

Examples:
  $MYBASENAME "Hello world"              # -> dlrow olleH (characters)
  $MYBASENAME "Hello world" " "          # -> world Hello (tokens)
  $MYBASENAME "one,two,three" ','        # -> three,two,one
  echo "abc" | $MYBASENAME               # -> cba
  echo "one two three" | $MYBASENAME " " # -> three two one

Options:
  -h, --help     Show this help message
  -v, --version  Show version information

EOF
}

REVERSE() {
    local string="$1"
    local delimiter="$2"
    local result=""
    
    if [ -z "$string" ]; then
        return 0
    fi
    
    if [ -z "$delimiter" ]; then
        # CHARACTER MODE: reverse elk karakter
        local len=${#string}
        for ((i=len-1; i>=0; i--)); do
            result+="${string:$i:1}"
        done
    else
        # TOKEN MODE: reverse tokens
        local tokens=()
        
        # Split op delimiter (zelfde truc als HEAD/TAIL)
        mapfile -d "$delimiter" -O 1 -t tokens <<< "$string""$stopper"
        
        # Cleanup laatste token
        if [ "${#tokens[@]}" -gt 0 ]; then
            last=${#tokens[@]}
            if [ "${tokens[$last]: -5}" = "$stopper" ]; then
                tokens[$last]="${tokens[$last]%?????}"
            else
                tokens[$last]="${tokens[$last]%??????}"
            fi
        fi
        
        # Bouw resultaat in omgekeerde volgorde
        for ((i=${#tokens[@]}; i>=1; i--)); do
            if [ -n "$result" ]; then
                result+="$delimiter"
            fi
            result+="${tokens[$i]}"
        done
    fi
    
    # Output zonder extra newline
    printf "%s" "$result"
}

# MAIN 
args=()

# Check voor pipe input
# Vervang de hele check door dit blok
if read -t 0.01 -r -n 1 eerste_karakter; then
    # Er is daadwerkelijk data. Lees de rest, voeg de marker toe en knip 'm er weer af.
    rest=$(cat; echo "$stopper")
    stdin_content="${eerste_karakter}${rest}"
    # Verwijder marker + eventuele newline
    stdin_content="${stdin_content%$stopper}"
    stdin_content="${stdin_content%$'\n'}"
    # we willen "" ook vangen.
    # if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    # fi
fi

debug=""
verbose=""
dryrun=""
silent=""
endofoptions=""
for arg in "$@"; do
    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
           
        -d|--debug)
            if [ -z "$endofoptions" ]; then
              debug="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --verbose)
            if [ -z "$endofoptions" ]; then
              verbose="1"
            else
              args+=("$arg")
            fi
            ;;
        
        --dryrun)
            if [ -z "$endofoptions" ]; then
              dryrun="1"
            else
              args+=("$arg")
            fi
            ;;
        
        -s|--silent)
            if [ -z "$endofoptions"]; then
              silent="1"
            else
              args+=("$arg")
            fi
            ;;
        
        
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1"  
            else
              args+=("$arg")
            fi
            ;;
                
        -*)
            if [ -z "$endofoptions" ]; then
              args+=("$arg")
            else
              echo "ERROR: Unknown option $arg" >&2
              show_usage
              exit 123
            fi
            ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
done

# Check bash versie (mapfile bestaat sinds bash 4.0)
if [ "${BASH_VERSINFO[0]}" -lt 4 ]; then
  echo "Warning: Your bash version is ${BASH_VERSINFO[0]}.${BASH_VERSINFO[1]}" >&2
  echo "mapfile needs bash 4.0 or higher. Upgrade bash for full support." >&2
  exit 123
fi

# Valideer aantal argumenten
if [ "${#args[@]}" -lt 1 ]; then
    echo "ERROR: Need at least text" >&2
    show_usage
    exit 1
fi

if [ "${#args[@]}" -gt 2 ]; then
    echo "ERROR: Too many arguments" >&2
    show_usage
    exit 1
fi

# Roep REVERSE aan
REVERSE "${args[@]}"
echo  # Newline voor prompt
exit $?
