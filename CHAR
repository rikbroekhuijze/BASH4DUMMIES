#!/bin/bash

VERSION="0.20.12"
MYBASENAME=$(basename "$0")

char1=$'\x01'
char2=$'\x02'
char3=$'\x03'
stopper="${char1}${char2}${char3}${char2}${char1}"

show_usage() {
    cat << EOF

Usage: $MYBASENAME <text> <start> [<end>]

Returns character(s) at specified position(s).

Parameters:
  text        - The string to extract from (can be passed via pipe)
  start       - Position to start (1 = first, -1 = last)
  end         - Optional: end position (inclusive)

Examples:
  $MYBASENAME "hello" 2           # -> e
  $MYBASENAME "hello" -1          # -> o
  $MYBASENAME "hello" 2 4         # -> ell
  $MYBASENAME "hello" 2 -1        # -> ello (2 to last)
  $MYBASENAME "hello" -3 -1       # -> llo (last three)
  
Options:
  -h, --help           Show this help message
  -v, --version        Show version information
  
  in case you want --help, --version or -- itself as an argument:
  --                   End of options 
          
;°)
  
EOF
}

# check only voor verbose & debug first.
verbose=""
debug=""
for arg in "$@"; do
    [ "$arg" = "--" ] && break
    if [ "$arg" = "--verbose" ]; then
        verbose=1
        break
    fi
    if [ "$arg" = "--debug" ]; then
        set -x
        break
    fi
done

CHAR() {
    
    local string="$1"
    local start="$2"
    local end="${3:-$2}"
    local len=${#string}
    
   #   echo "DEBUG: len=$len" >&2
   #   echo "DEBUG: string als bytes:" >&2
   #   for ((i=0; i<len; i++)); do
   #       char="${string:$i:1}"
   #       printf "  %d: '%s' (ASCII %d)\n" $((i+1)) "$char" "'$char" >&2
   #   done
    
    # Validatie
    if [[ ! "$start" =~ ^-?[0-9]+$ ]] || [[ ! "$end" =~ ^-?[0-9]+$ ]]; then
        echo "$MYBASENAME: Positions must be integers" >&2
        return 123
    fi
    
    # Converteer naar 0-based indices
    if [ "$start" -gt 0 ]; then
        start=$((start - 1))
    elif [ "$start" -lt 0 ]; then
        start=$((len + start))
    fi
    
    if [ "$end" -gt 0 ]; then
        end=$((end - 1))
    elif [ "$end" -lt 0 ]; then
        end=$((len + end))
    fi
    
    # Zorg dat start <= end
    if [ "$start" -gt "$end" ]; then
        local tmp="$start"
        start="$end"
        end="$tmp"
    fi
    
    # Check of binnen bereik
    [ "$start" -lt 0 ] && start=0
    [ "$end" -ge "$len" ] && end=$((len - 1))
    
    # Extract karakters
    local result=""
    for ((i=start; i<=end; i++)); do
        result+="${string:$i:1}"
    done
    
    # Alleen output als resultaat niet leeg is
    if [ -n "$result" ]; then
        # Gebruik printf om extra newline te voorkomen
       #  printf "%s" "$result"
       echo "$result"
    fi
    
}

# MAIN 
args=()

#
# Check voor pipe input
if IFS='' read -t 0.01 -r -n 1 eerste_karakter; then
    # Er is daadwerkelijk data. Lees de rest, voeg de marker toe en knip 'm er weer af. (grab the newline)
    rest=$(cat; echo "$stopper")
    stdin_content="${eerste_karakter}${rest}"
    # Verwijder marker + eventuele newline
    stdin_content="${stdin_content%$stopper}"
    stdin_content="${stdin_content%$'\n'}"
    # we willen "" ook vangen.
    # if [ -n "$stdin_content" ]; then
        args+=("$stdin_content")
    # fi
# else
  # # pipe or file
  # # bacon (en anderen) openen een pipe intern. beiden (-p en -f ) reageren daarop.
  # if [ -p /dev/stdin ] || [ -f /dev/stdin ] ; then
  #   stdin_content=$(cat; echo "$stopper")
  #   stdin_content="${stdin_content%$stopper}"
  #   stdin_content="${stdin_content%$'\n'}"
  #   # we willen "" ook vangen.
  #   # if [ -n "$stdin_content" ]; then
  #       args+=("$stdin_content")
  #   # fi
 #  fi
fi

[ -n "$verbose" ] && echo
endofoptions=""
for arg in "$@"; do
   
    [ -n "$verbose" ] && echo "arg : $arg"
    
    case "$arg" in
        
        -h|--help)
            
            if [ -z "$endofoptions" ]; then
              show_usage
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--version)
            if [ -z "$endofoptions" ]; then
              echo "$VERSION"
              exit 0
            fi
            args+=("$arg")
            ;;
        
        -v|--verbose|-d|--debug)
        
           if [ -n "$endofoptions" ]; then args+=("$arg") ; fi
           ;;
            
        --)
            if [ -z "$endofoptions" ]; then
              shift
              endofoptions="1" 
              endofoptionstoggle="1"
            else
              args+=("$arg")
            fi
            ;;
                
    #    -*)
    #        # what about a megative number ?
    #        if [ -z "$endofoptions" ]; then
    #          args+=("$arg")
    #        else
    #          echo "$MYBASENAME: Unknown option $arg" >&2
    #          exit 123
    #        fi
    #        ;;
          
        *) 
            args+=("$arg")
            ;;
    esac
    
done

if [ -n "$verbose" ] ; then
  echo
  echo "number of arguments : ${#args[@]}"
  echo "stdin_content : =>$stdin_content<="
  for ((abc=0; abc<${#args[@]}; abc++)); do
    echo "argument $abc : =>${args[$((abc))]}<="
  done
  echo
fi

# Valideer aantal argumenten
if [ "${#args[@]}" -lt 2 ]; then
    echo "$MYBASENAME: Need at least text and start position" >&2
    # show_usage
    exit 123
fi

if [ "${#args[@]}" -gt 3 ]; then
    echo "$MYBASENAME: Too many arguments" >&2
    # show_usage
    exit 123
fi

CHAR "${args[@]}"
exit $?
